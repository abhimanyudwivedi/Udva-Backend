# ============================================================
# Udva — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://udva:changeme@localhost:5432/udva

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# LLM APIs
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=  # optional — leave blank until you have Gemini credits
PERPLEXITY_API_KEY=pplx-...

# ------------------------------------------------------------
# Data source APIs
# ------------------------------------------------------------
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=udva/1.0
SERPER_API_KEY=your_serper_api_key

# ------------------------------------------------------------
# Auth / JWT
# ❯ Generate: python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------
JWT_SECRET_KEY=replace_with_64_char_random_hex_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------
# Payments — DodoPayments
# Docs: https://docs.dodopayments.com
# ------------------------------------------------------------
DODO_PAYMENTS_API_KEY=your_dodo_api_key
DODO_WEBHOOK_SECRET=your_dodo_webhook_secret
DODO_PRODUCT_SOLO=your_solo_product_id
DODO_PRODUCT_INDIE=your_indie_product_id
DODO_PRODUCT_STUDIO=your_studio_product_id
DODO_PRODUCT_AGENCY=your_agency_product_id
DODO_ENVIRONMENT=test_mode   # change to live_mode for production

# ------------------------------------------------------------
# Email — Resend
# ------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=shipfast.pvt@gmail.com

# ------------------------------------------------------------
# Encryption — Reddit account passwords (AES-256)
# ❯ Generate: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# ------------------------------------------------------------
ACCOUNT_ENCRYPTION_KEY=replace_with_base64_encoded_32_byte_key

# ------------------------------------------------------------
# Error tracking — Sentry (leave blank to disable locally)
# ------------------------------------------------------------
SENTRY_DSN=https://...@sentry.io/...

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
